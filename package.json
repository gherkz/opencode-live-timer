{
  "name": "opencode-live-timer",
  "version": "0.0.0",
  "description": "opencode plugin that adds a live session timer",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "dev": "bun --watch src/index.ts",
    "install": "bun build src/index.ts --outfile $HOME/.config/opencode/plugins/live-timer.js --target bun --format esm",
    "uninstall": "bun run scripts/uninstall.ts"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@opencode-ai/plugin": "*",
    "@types/bun": "^1.1.14",
    "typescript": "^5.6.3"
  }
}
